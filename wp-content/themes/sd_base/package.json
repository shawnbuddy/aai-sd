{
  "name": "sd_base",
  "version": "1.1.0",
  "description": "Generic Timber + ACF WordPress base theme",
  "author": "Sandstorm Design",
  "license": "GPL-2.0+",
  "type": "module",
  "browserslist": [
    "last 2 versions and not dead",
    ">= 1%",
    ">= 1% in US"
  ],
  "scripts": {
    "build": "npm run build:css",
    "build:css": "node tools/build-scss.mjs",
    "watch": "npm run watch:css",
    "watch:css": "node tools/build-scss.mjs --watch --browsersync"
  },
  "devDependencies": {
    "browser-sync": "^3.0.3",
    "glob": "^11.0.3",
    "sass": "^1.95.0"
  },
  "volta": {
    "node": "20.19.3"
  }
}
