<!DOCTYPE html>
<html {{ site.language_attributes }}>
  <head>
    <meta charset="{{ site.charset }}" />
    <meta name="viewport" content="width=device-width user-scalable=yes" />
    {# Use the full WordPress document title for the browser tab #}
    <title>{{ document_title }}</title>
    {% do action('get_header') %}
    {{ function('wp_head') }}
  </head>

  <body class="{{ body_class }}">
    {{ function('wp_body_open') }}
    <a class="skip-link screen-reader-text" href="#content">{{ _e('Skip to content') }}</a>
    {% include 'header/header.twig' %}

    <main id="content" class="site-main {{ (home) ? 'homepage' : 'interior' }}">
      {% set template_name = template|default('index') %}
      {% include [
        'src/4-pages/' ~ template_name ~ '.twig',
        'src/4-pages/index.twig'
      ] %}
    </main>

    {% include 'footer/footer.twig' %}
    {{ function('wp_footer') }}
    {% do action('get_footer') %}
  </body>
</html>
