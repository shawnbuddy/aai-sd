# macOS
.DS_Store

# IDE/editor files
.idea/
.vscode/
*.swp
*.swo

# Environment files
.env
.env.*
!.env.example

# Composer dependencies
/vendor/

# DDEV generated/import artifacts
.ddev/.importdb*
.ddev/.downloads/
.ddev/db_snapshots/
.ddev/.global_commands/
.ddev/.homeadditions/
wp-config.php

# Local development
*.code-workspace
.vscrof

# WordPress core (installed to web/wp/ by Composer)
/web/wp/

# WordPress content that should not be committed
/web/wp-content/uploads/
/web/wp-content/upgrade/
/web/wp-content/cache/
/web/wp-content/backup-db/
/web/wp-content/backups/
/web/wp-content/ai1wm-backups/
/web/wp-content/debug.log

# Composer-managed plugins
/web/wp-content/plugins/*
!/web/wp-content/plugins/.gitkeep
!/web/wp-content/plugins/sd-cf7-salesforce/
!/web/wp-content/plugins/sd-cf7-salesforce/**

# Keep custom themes trackable
!/web/wp-content/themes/
/web/wp-content/themes/*
!/web/wp-content/themes/sd_base/

# Ignore generated theme dependencies/build artifacts
/web/wp-content/themes/sd_base/node_modules/
/web/wp-content/themes/sd_base/vendor/
/web/wp-content/themes/sd_base/dist/
/web/wp-content/themes/sd_base/.DS_Store

# WordPress generated files
/web/wp-content/object-cache.php
/web/wp-content/advanced-cache.php

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database dumps
*.sql
*.sql.gz
/database/*
!/database/wordpress-db.sql.gz
