{
  "repositories": [
    {
      "name": "wpackagist",
      "type": "composer",
      "url": "https://wpackagist.org"
    },
    {
      "type": "composer",
      "url": "https://connect.advancedcustomfields.com"
    }
  ],
  "require": {
    "composer/installers": "^2.3",
    "timber/timber": "^2.4",
    "wpengine/advanced-custom-fields-pro": "^6.8",
    "wpackagist-plugin/polylang": "^3.8",
    "wpackagist-plugin/the-events-calendar": "^6.16",
    "wpackagist-plugin/contact-form-7": "^6.1",
    "wpackagist-plugin/cf7-conditional-fields": "^2.7",
    "wpackagist-plugin/contact-form-7-dynamic-text-extension": "^5.0",
    "wpackagist-plugin/cf7-repeatable-fields": "^2.0",
    "wpackagist-plugin/contact-form-7-accessible-defaults": "^1.1",
    "wpackagist-plugin/message-popup-for-contact-form-7": "^1.0",
    "wpackagist-plugin/cf7-multi-step": "^2.8",
    "wpackagist-plugin/wpcf7-redirect": "^3.2"
  },
  "extra": {
    "installer-paths": {
      "wp-content/plugins/{$name}/": [
        "type:wordpress-plugin"
      ],
      "wp-content/mu-plugins/{$name}/": [
        "type:wordpress-muplugin"
      ],
      "wp-content/themes/{$name}/": [
        "type:wordpress-theme"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
